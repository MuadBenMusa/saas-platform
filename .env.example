# Production-like backend environment example.
# Use placeholders only. Put real values in DigitalOcean App Platform env vars.

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<database>
SPRING_DATASOURCE_USERNAME=<database-user>
SPRING_DATASOURCE_PASSWORD=<database-password>

# Keycloak / OpenID Connect
KEYCLOAK_CLIENT_ID=oauth2-authorization-flow
KEYCLOAK_CLIENT_SECRET=<keycloak-client-secret>
KEYCLOAK_ISSUER_URI=https://<keycloak-domain>/realms/<realm>

# Application redirects
APP_LOGIN_SUCCESS_REDIRECT_URI=https://<app-domain>/dashboard
APP_POST_LOGOUT_REDIRECT_URI=https://<app-domain>/login?logout

# Local dev note:
# With SPRING_PROFILES_ACTIVE=dev, datasource and redirect defaults live in
# backend/src/main/resources/application-dev.yaml. Set only the local secrets
# you need, such as KEYCLOAK_CLIENT_SECRET.
